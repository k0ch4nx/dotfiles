@@ -4,6 +4,7 @@ local config = lazy("cokeline.config")
 
 local rep = string.rep
 local insert = table.insert
+local concat = table.concat
 local remove = table.remove
 
 local iter = vim.iter
@@ -138,6 +139,44 @@ Component.render = function(self, context)
   return component
 end
 
+---@param text string
+---@param start_col number
+---@param width number
+---@return string
+local function strwidthpart(text, start_col, width)
+  if width <= 0 then
+    return ""
+  end
+
+  local chars = {}
+  local col = 0
+  local slice_col = start_col
+  local len = fn.strcharlen(text)
+  local end_col = start_col + width
+
+  for i = 0, len - 1 do
+    local char = fn.strcharpart(text, i, 1)
+    local char_width = fn.strwidth(char)
+    local next_col = col + char_width
+
+    if col >= start_col and next_col <= end_col then
+      if col > slice_col then
+        insert(chars, rep(" ", col - slice_col))
+      end
+      insert(chars, char)
+      slice_col = next_col
+    end
+
+    col = next_col
+  end
+
+  if slice_col < end_col then
+    insert(chars, rep(" ", end_col - slice_col))
+  end
+
+  return concat(chars)
+end
+
 ---@generic Cx
 ---@param self      Component<Cx>
 ---@param to_width  number
