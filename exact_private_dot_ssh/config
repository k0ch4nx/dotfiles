# https://man.openbsd.org/man5/ssh_config

Include ~/.orbstack/ssh/config

ServerAliveInterval 60
ExitOnForwardFailure yes
StrictHostKeyChecking no
UserKnownHostsFile /dev/null
LogLevel ERROR

Host ubuntu-server
    HostName ubuntu-server.ssh.k0ch4nx.dev
    User k0ch4nx
    ProxyCommand cloudflared access ssh --hostname %h
    IdentityFile ~/.ssh/id_ed25519_sk
    IdentitiesOnly yes
    TCPKeepAlive yes

Host gcp
    HostName gcp.ssh.k0ch4nx.dev
    User k0ch4nx
    ProxyCommand cloudflared access ssh --hostname %h
    IdentityFile ~/.ssh/id_ed25519_sk
    IdentitiesOnly yes
    TCPKeepAlive yes

Host github.com-pers
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_sk_gh_auth_pers
    IdentitiesOnly yes

Host github.com-work
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_gh_work
    IdentitiesOnly yes
