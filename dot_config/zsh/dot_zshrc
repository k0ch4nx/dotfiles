HISTFILE=${XDG_STATE_HOME}/zsh/history

setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt globdots

# https://thevaluable.dev/zsh-completion-guide-examples
zstyle ":completion:*" menu select
zstyle ":completion:*" cache-path "${XDG_CACHE_HOME}/zsh/.zcompcache"

HISTORY_SUBSTRING_SEARCH_ENSURE_UNIQUE=1
zle_highlight=(${zle_highlight:#paste:*} paste:standout)

# https://github.com/jeffreytse/zsh-vi-mode?tab=readme-ov-file#command-line-initial-mode
ZVM_LINE_INIT_MODE=${ZVM_MODE_INSERT}

# https://docs.brew.sh/Shell-Completion#configuring-completions-in-zsh
if type brew &>/dev/null; then
    FPATH="$(brew --prefix)/share/zsh/site-functions:${FPATH}"
    FPATH="$(rustc --print sysroot)/share/zsh/site-functions:${FPATH}"

    autoload -Uz compinit
    # https://zsh.sourceforge.io/Doc/Release/Completion-System.html#Use-of-compinit
    compinit -d "${XDG_CACHE_HOME}/zsh/.zcompdump"

    autoload -U +X bashcompinit
    bashcompinit

    complete -o nospace -C "$(brew --prefix)/bin/terraform" terraform
fi

# https://github.com/Aloxaf/fzf-tab?tab=readme-ov-file#install
source "$(brew --prefix)/share/fzf-tab/fzf-tab.plugin.zsh"

source "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$(brew --prefix)/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
source "$(brew --prefix)/share/zsh-history-substring-search/zsh-history-substring-search.zsh"
source "$(brew --prefix)/share/zsh-vi-mode/zsh-vi-mode.plugin.zsh"

# https://github.com/Homebrew/homebrew-cask/issues/143596#issuecomment-1502165025
source "$(brew --prefix)/share/zsh/site-functions/_google_cloud_sdk"
# source <(mas --generate-completion-script zsh)
source <(rustup completions zsh rustup)

# https://github.com/jeffreytse/zsh-vi-mode/issues/242#issuecomment-1721033298
function zvm_after_init() {
    # https://github.com/junegunn/fzf?tab=readme-ov-file#setting-up-shell-integration
    source <(fzf --zsh)
}

# https://github.com/zsh-users/zsh-history-substring-search?tab=readme-ov-file#usage
bindkey -M vicmd "k" history-substring-search-up
bindkey -M vicmd "j" history-substring-search-down

function eza() {
    local opts=(
        # https://github.com/eza-community/eza#display-options
        "--long"
        "--color=always"
        "--color-scale=age"
        "--color-scale-mode=gradient"
        "--icons=auto"
        "--hyperlink"

        # https://github.com/eza-community/eza#filtering-options
        "--all"
        "--group-directories-first"

        # https://github.com/eza-community/eza#long-view-options
        "--binary"
        "--header"
        "--links"
        "--modified"
        "--mounts"
        "--blocksize"
        "--accessed"
        "--created"
        "--changed"
        "--git"
        "--git-repos"
        "--time-style=long-iso"
        "--total-size"
        "--octal-permissions"
    )

    command eza "${opts[@]}" "$@"
}

function gamdl {
    command gamdl --config-path "${XDG_CONFIG_HOME}/gamdl/config.ini" "$@"
}

function ghqf {
    local eza_opts=(
        "--long"
        "--color=always"
        "--color-scale=age"
        "--color-scale-mode=gradient"
        "--icons=auto"
        "--all"
        "--group-directories-first"
        "--git"
        "--no-permissions"
        "--no-filesize"
        "--no-user"
        "--no-time"
    )

    local preview_cmd="\$(brew --prefix)/bin/eza \$(ghq root)/{} ${eza_opts[@]}"

    cd "$(ghq root)/$(ghq list | fzf --preview "${preview_cmd}")"
}

# https://mise.jdx.dev/getting-started.html#activate-mise
eval "$(mise activate zsh)"
# https://github.com/nvbn/thefuck?tab=readme-ov-file#installation
eval "$(oh-my-posh init zsh --config ${XDG_CONFIG_HOME}/oh-my-posh/themes/default.json)"
if command -v fastfetch &>/dev/null; then
    if [ ${SHLVL} -eq 1 ]; then
        fastfetch
    fi
fi
